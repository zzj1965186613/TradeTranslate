{
    "manifest_version":  3,
    "name":  "TradeTranslate",
    "version":  "1.0.0",
    "description":  "Seamless two-way EN↔ZH translation for WhatsApp Web",
    "permissions":  [
                        "storage"
                    ],
    "host_permissions":  [
                             "*://web.whatsapp.com/*",
                             "https://api.deepseek.com/*"
                         ],
    "background":  {
                       "service_worker":  "background.js",
                       "type":  "module"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "*://web.whatsapp.com/*"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle"
                            }
                        ],
    "action":  {
                   "default_popup":  "popup.html",
                   "default_title":  "TradeTranslate"
               },
    "icons":  {
                  "16":  "icons/icon16.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              }
}